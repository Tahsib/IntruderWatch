# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_USER=admin
RABBITMQ_PASS=admin

# Stream credentials (default for most cameras)
STREAM_IP=192.168.50.88
STREAM_USERNAME=your_username
STREAM_PASSWORD=your_password

# Twilio
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890
ALERT_PHONE_NUMBERS=+1234567890

# Active camera profiles (comma-separated)
# Available: cam1, cam2, cam3, cam4, cam5, cam7, cam8
COMPOSE_PROFILES=cam2,cam3,cam4,cam7,cam8
