{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": 1,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "title": "Total Alerts (24h)",
      "type": "stat",
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["sum"] }
      },
      "targets": [{ "expr": "sum(increase(alert_service_alerts_total[24h]))", "refId": "A" }]
    },
    {
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "title": "Healthy Cameras",
      "type": "stat",
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 4 },
              { "color": "green", "value": 8 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [{ "expr": "sum(up{job=\"frame_capturer\"})", "refId": "A" }]
    },
    {
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "id": 3,
      "title": "Active Detectors",
      "type": "stat",
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [{ "expr": "count(up{job=\"human_detector\"})", "refId": "A" }]
    },
    {
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "id": 4,
      "title": "System Error Rate",
      "type": "stat",
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.01 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["mean"] }
      },
      "targets": [{ "expr": "sum(rate(human_detector_errors_total[5m])) + sum(rate(frame_capturer_errors_total[5m]))", "refId": "A" }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 4 },
      "id": 100,
      "title": "Infrastructure Health",
      "type": "row"
    },
    {
      "gridPos": { "h": 5, "w": 24, "x": 0, "y": 5 },
      "id": 10,
      "title": "Service Availability Timeline",
      "type": "state-timeline",
      "datasource": "Prometheus",
      "targets": [
        { "expr": "up{job=\"rabbitmq\"}", "legendFormat": "RabbitMQ", "refId": "A" },
        { "expr": "up{job=\"alert_service\"}", "legendFormat": "Alert Service", "refId": "B" },
        { "expr": "up{job=\"viewer_service\"}", "legendFormat": "Viewer Service", "refId": "C" }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 0, "fillOpacity": 70 },
          "mappings": [
            { "options": { "0": { "color": "red", "index": 0, "text": "OFFLINE" }, "1": { "color": "green", "index": 1, "text": "ONLINE" } }, "type": "value" }
          ]
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 10 },
      "id": 200,
      "title": "Camera Fleet (Ingestion)",
      "type": "row"
    },
    {
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 11 },
      "id": 20,
      "title": "Camera Connection Status",
      "type": "stat",
      "datasource": "Prometheus",
      "options": {
        "colorMode": "background",
        "justifyMode": "center",
        "orientation": "horizontal",
        "textMode": "name"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "color": "red", "text": "OFFLINE" }, "1": { "color": "green", "text": "ONLINE" } }, "type": "value" }
          ]
        }
      },
      "targets": [{ "expr": "up{job=\"frame_capturer\"}", "legendFormat": "CAM {{camera_id}}", "refId": "A" }]
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "id": 21,
      "title": "Ingestion FPS per Camera",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [{ "expr": "sum(rate(frame_capturer_sent_total[1m])) by (camera_id)", "legendFormat": "CAM {{camera_id}}", "refId": "A" }]
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "id": 22,
      "title": "Duplicate/Skipped Frames (Noise)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [{ "expr": "sum(rate(frame_capturer_skipped_total[5m])) by (reason, camera_id)", "legendFormat": "CAM {{camera_id}} - {{reason}}", "refId": "A" }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 300,
      "title": "Detection Fleet (Processing)",
      "type": "row"
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "id": 30,
      "title": "Detector Processing FPS",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [{ "expr": "sum(rate(human_detector_frames_processed_total[1m])) by (worker_id)", "legendFormat": "Worker {{worker_id}}", "refId": "A" }]
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "id": 31,
      "title": "YOLO Processing Latency",
      "type": "timeseries",
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [{ "expr": "sum(rate(human_detector_processing_seconds_sum[1m])) by (worker_id) / sum(rate(human_detector_processing_seconds_count[1m])) by (worker_id)", "legendFormat": "{{worker_id}}", "refId": "A" }]
    },
    {
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 32 },
      "id": 32,
      "title": "Detector Replica Load Heatmap",
      "type": "state-timeline",
      "datasource": "Prometheus",
      "targets": [{ "expr": "human_detector_active_processing", "legendFormat": "Worker {{worker_id}}", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 38 },
      "id": 400,
      "title": "Message Pipeline (RabbitMQ)",
      "type": "row"
    },
    {
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 39 },
      "id": 40,
      "title": "Queue Depth (Backlog)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [{ "expr": "rabbitmq_queue_messages{queue=~\"frame_queue|alert_queue\"}", "legendFormat": "{{queue}}", "refId": "A" }]
    },
    {
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 39 },
      "id": 41,
      "title": "Message Throughput (RabbitMQ)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        { "expr": "sum(rate(rabbitmq_queue_messages_published_total[1m]))", "legendFormat": "In (Pub)", "refId": "A" },
        { "expr": "sum(rate(rabbitmq_queue_messages_delivered_total[1m]))", "legendFormat": "Out (Del)", "refId": "B" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 47 },
      "id": 500,
      "title": "Host Resources",
      "type": "row"
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 48 },
      "id": 50,
      "title": "Host CPU Usage",
      "type": "gauge",
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } },
      "targets": [{ "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)", "refId": "A" }]
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 48 },
      "id": 51,
      "title": "Host RAM Usage",
      "type": "gauge",
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        { "expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes", "legendFormat": "Used", "refId": "A" }
      ]
    }
  ],
  "schemaVersion": 34,
  "style": "dark",
  "tags": ["intruder-detection", "monitoring"],
  "time": { "from": "now-1h", "to": "now" },
  "title": "Intruder Watch: Deep System Observability",
  "version": 3
}
